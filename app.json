{
  "expo": {
    "name": "grok-voice-demo",
    "slug": "grok-voice-demo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "chat",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.bacon.grok-voice-demo"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "server"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-system-ui",
      "expo-status-bar",
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "Allow $(PRODUCT_NAME) to use your microphone to talk to the Grok voice agent.",
          "androidPermissions": [
            "android.permission.RECORD_AUDIO",
            "android.permission.FOREGROUND_SERVICE",
            "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
