# Anthropic API key used by the text chat route (app/api/chat+api.ts).
ANTHROPIC_API_KEY=

# xAI API key used by the Grok voice agent route (app/api/voice-session+api.ts).
# Get one at https://console.x.ai
XAI_API_KEY=

# Optional: override the Grok voice model and voice.
# GROK_VOICE_MODEL=grok-voice-latest
# GROK_VOICE=eve

# Set to 1 to use mock streaming responses instead of calling the Anthropic API.
# EXPO_PUBLIC_MOCK_AI=1
