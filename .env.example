# xAI API key used by the text chat route (app/api/chat+api.ts) via @ai-sdk/xai
# AND the NATIVE voice agent (app/api/voice-session+api.ts), which mints an
# ephemeral token for a direct xAI realtime WebSocket.
# Get one at https://console.x.ai
XAI_API_KEY=

# Vercel AI Gateway key used by the WEB voice agent (app/api/realtime-token+api.ts),
# which mints a realtime token via the AI SDK's experimental_useRealtime hook.
# Configure your xAI key as a bring-your-own-key credential in the AI Gateway
# dashboard. https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Optional: override the Grok voice model and voice.
# GROK_VOICE_MODEL=grok-voice-latest   # native (xAI direct)
# GROK_VOICE=eve
# GROK_REALTIME_MODEL=xai/grok-voice-think-fast-1.0   # web (AI Gateway)

# Set to 1 to use mock streaming responses instead of calling the API.
# EXPO_PUBLIC_MOCK_AI=1
