# xAI API key used by everything: the text chat route (app/api/chat+api.ts) via
# @ai-sdk/xai, and the voice agent on all platforms (app/api/voice-session+api.ts),
# which mints an ephemeral xAI realtime token. No Vercel AI Gateway key needed.
# Get one at https://console.x.ai
XAI_API_KEY=

# Optional: override the Grok voice model and voice.
# GROK_VOICE_MODEL=grok-voice-latest
# GROK_VOICE=eve

# Set to 1 to use mock streaming responses instead of calling the API.
# EXPO_PUBLIC_MOCK_AI=1
